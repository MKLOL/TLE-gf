# Copy to /etc/tle-backup/backup.env  (chmod 600 — contains a password)
# These are the SSH credentials for the SOURCE (the TLE-gf server we pull from).

TLE_SRC_HOST=YOUR_TLE_GF_SERVER_IP
TLE_SRC_PORT=22
TLE_SRC_USER=YOUR_SSH_USER
TLE_SRC_PASSWORD=CHANGE_ME
# Prefer key auth instead — leave TLE_SRC_PASSWORD empty and set:
# TLE_SSH_KEY=/etc/tle-backup/id_ed25519

# Path to the live user.db on the source server.
TLE_SRC_DB=/opt/tle-gf/data/db/user.db

# Where backups are stored on THIS (backup) server, and how long to keep them.
TLE_BACKUP_DIR=/var/backups/tle-gf
TLE_RETENTION_DAYS=7

# Temp path for the consistent snapshot on the source (auto-cleaned each run).
TLE_REMOTE_SNAPSHOT=/tmp/tle_user_db_snapshot.db
